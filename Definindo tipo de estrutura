#include <stdio.h>

#define MAX 100

typedef struct {
    int id;
    char nome[100];
    char autor[100];
    char editora[100];
} Livro;

int main() {

    Livro livros[MAX];

    int quantidade;
    int i;

    printf("Quantos livros deseja cadastrar? ");
    scanf("%d", &quantidade);

    if(quantidade > MAX) {
        printf("Limite maximo de livros excedido!\n");
        return 0;
    }

    for(i = 0; i < quantidade; i++) {

        printf("\n==== Cadastro do Livro %d ====\n", i + 1);

        printf("ID do livro: ");
        scanf("%d", &livros[i].id);

        printf("Nome do livro: ");
        scanf(" %[^\n]", livros[i].nome);

        printf("Autor do livro: ");
        scanf(" %[^\n]", livros[i].autor);

        printf("Editora do livro: ");
        scanf(" %[^\n]", livros[i].editora);
    }

    printf("\n==== LIVROS CADASTRADOS ====\n");

    for(i = 0; i < quantidade; i++) {

        printf("\nLivro %d\n", i + 1);
        printf("ID: %d\n", livros[i].id);
        printf("Nome: %s\n", livros[i].nome);
        printf("Autor: %s\n", livros[i].autor);
        printf("Editora: %s\n", livros[i].editora);
    }

    return 0;
}
